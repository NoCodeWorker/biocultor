# ─── Database (PostgreSQL en producción) ────────────────────────────────
# Local: postgresql://user:pass@localhost:5432/biocultor
# Docker: postgresql://biocultor:PASS@db:5432/biocultor
DATABASE_URL="postgresql://biocultor:CHANGE_ME@db:5432/biocultor?schema=public"

# ─── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://biocultor.com
NODE_ENV=production

# ─── Stripe ─────────────────────────────────────────────────────────────
# Test: sk_test_... / whsec_...  | Live: sk_live_...
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ─── Email (Resend) ─────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE

# ─── Envíos (Packlink) ──────────────────────────────────────────────────
PACKLINK_API_KEY=REPLACE

# ─── IA (DeepSeek para el chatbot agronómico) ────────────────────────────
DEEP_SEEK_API_KEY=sk-REPLACE

# ─── Postgres (solo se usan en docker-compose para inicializar el contenedor db) ─
POSTGRES_USER=biocultor
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=biocultor
